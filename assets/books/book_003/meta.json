{
  "id": "book_003",
  "title": "三只小猪",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "从前，有三只小猪和妈妈住在一起。"
        },
        {
          "id": "s2",
          "text": "有一天，猪妈妈说：“孩子们，你们长大了，去各自盖一座自己的房子吧。”"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "老大很懒，用稻草盖了一座草房。"
        },
        {
          "id": "s4",
          "text": "老二也怕累，用木头盖了一座木房。"
        },
        {
          "id": "s5",
          "text": "只有老三最勤快，一块块地垒起砖头，盖了一座结实的砖房。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "一天，大灰狼来了。他对着草房一吹，草房就倒了。"
        },
        {
          "id": "s7",
          "text": "他又对着木房一吹，木房也倒了。"
        },
        {
          "id": "s8",
          "text": "老大和老二赶紧跑到老三的砖房里躲起来。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s9",
          "text": "大灰狼使劲吹砖房，可砖房一动也不动。"
        },
        {
          "id": "s10",
          "text": "他就从烟囱爬进去，结果“哎呀”一声被热水烫得跑掉了。"
        },
        {
          "id": "s11",
          "text": "从此，三只小猪安心地住在砖房里，再也没人敢来欺负他们。"
        }
      ]
    }
  ]
}
