{
  "id": "book_017",
  "title": "坐井观天",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "一只青蛙从小住在井底。"
        },
        {
          "id": "s2",
          "text": "他抬头看天，觉得天就只有井口那么大。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "一天，一只小鸟飞到井沿上休息。"
        },
        {
          "id": "s4",
          "text": "青蛙问小鸟：“你从哪里来呀？”"
        },
        {
          "id": "s5",
          "text": "小鸟说：“我从天边飞来，飞了一百多里，又渴又累。”"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "青蛙惊讶地说：“天只有井口大，你怎么可能飞那么远？”"
        },
        {
          "id": "s7",
          "text": "小鸟笑了：“天无边无际，大得很呢！”"
        },
        {
          "id": "s8",
          "text": "青蛙摇摇头，一点也不相信。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s9",
          "text": "小鸟鼓励他：“你跳出来看看就知道了。”"
        },
        {
          "id": "s10",
          "text": "青蛙用力一跳，跳出了井口。"
        },
        {
          "id": "s11",
          "text": "他看到蓝天白云、高山大河，惊讶得说不出话来。"
        },
        {
          "id": "s12",
          "text": "原来，世界比井里看到的大得多呀。"
        }
      ]
    }
  ]
}
