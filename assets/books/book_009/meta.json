{
  "id": "book_009",
  "title": "青蛙王子",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "小公主最喜欢在井边玩金球。"
        },
        {
          "id": "s2",
          "text": "一天，金球掉进了深深的井里，公主急得哭了起来。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "一只青蛙冒出水面说：“别哭，我帮你捡回来。”"
        },
        {
          "id": "s4",
          "text": "“不过，你要答应做我的朋友。”"
        },
        {
          "id": "s5",
          "text": "公主答应了，青蛙潜下水，把金球捞了上来。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "可是，公主觉得青蛙丑，不想理他。"
        },
        {
          "id": "s7",
          "text": "国王知道后说：“答应了别人的事，就一定要做到。”"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "公主红着脸，让青蛙和自己同桌吃饭。"
        },
        {
          "id": "s9",
          "text": "这时，青蛙变成了一位英俊的王子。"
        },
        {
          "id": "s10",
          "text": "原来，他被人施了魔法，是公主的守信解除了它。"
        }
      ]
    }
  ]
}
