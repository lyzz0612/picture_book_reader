{
  "id": "book_004",
  "title": "龟兔赛跑",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 4,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "森林里，兔子跑得飞快，常常嘲笑乌龟：“你爬得这么慢，真是太好笑了。”"
        },
        {
          "id": "s2",
          "text": "乌龟不生气，平静地说：“那我们比一场吧，看谁先到山顶。”"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "比赛开始了，兔子一溜烟跑到了前面。"
        },
        {
          "id": "s4",
          "text": "他回头一看，乌龟还远远落在后面，心想：“反正他追不上，我先睡一觉。”"
        },
        {
          "id": "s5",
          "text": "兔子就在树下呼呼睡着了。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "乌龟没有停下，一步一步地往前爬。"
        },
        {
          "id": "s7",
          "text": "他爬呀爬，终于超过了熟睡的兔子。"
        },
        {
          "id": "s8",
          "text": "等兔子醒来，急忙冲向山顶，却发现乌龟已经到了。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s9",
          "text": "兔子红着脸低下了头。"
        },
        {
          "id": "s10",
          "text": "乌龟笑着说：“只要坚持，慢一点也能赢。”"
        }
      ]
    }
  ]
}
