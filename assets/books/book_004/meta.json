  "pages": [
    {
      "id": "p1",
      "segments": [
        { "id": "s1", "text": "一只小蚂蚁发现了一块大大的面包。" },
        { "id": "s2", "text": "可是面包太大了，小蚂蚁搬不动。" },
        { "id": "s3", "text": "小蚂蚁没有放弃，它跑回蚂蚁洞去找帮手。" }
      ]
    },
    {
      "id": "p2",
      "segments": [
        { "id": "s4", "text": "一群蚂蚁来了，它们排着队，齐心协力。" },
        { "id": "s5", "text": "大家一起使劲，终于把面包搬回了家。" }
      ]
    },
    {
      "id": "p3",
      "segments": [
        { "id": "s6", "text": "小蚂蚁明白了，团结就是力量！" },
        { "id": "s7", "text": "只要大家一起努力，没有什么做不到的。" }
      ]
    }
  ]
}