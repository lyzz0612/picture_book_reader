{
  "id": "book_007",
  "title": "小红帽",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "有个小女孩，总戴着红帽子，大家都叫她小红帽。"
        },
        {
          "id": "s2",
          "text": "一天，妈妈让她去探望生病的外婆，叮嘱她：“走大路，别和陌生人说话。”"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "半路上，小红帽遇到一只大灰狼。"
        },
        {
          "id": "s4",
          "text": "大灰狼骗她说：“那边有美丽的花，去采一些送给外婆吧。”"
        },
        {
          "id": "s5",
          "text": "小红帽忘了妈妈的话，走进了小路。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "大灰狼先跑到外婆家，假装成外婆躺在床上。"
        },
        {
          "id": "s7",
          "text": "小红帽来了，觉得外婆今天有些奇怪。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "幸好，猎人正好路过，听到了声音。"
        },
        {
          "id": "s9",
          "text": "他冲进来赶走了大灰狼，救出了外婆和小红帽。"
        },
        {
          "id": "s10",
          "text": "小红帽明白了：要听妈妈的话，不能和陌生人搭话。"
        }
      ]
    }
  ]
}
