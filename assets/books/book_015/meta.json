{
  "id": "book_015",
  "title": "拔萝卜",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "老爷爷在地里种了一个大萝卜。"
        },
        {
          "id": "s2",
          "text": "萝卜长得又大又红，老爷爷高兴地来拔。"
        },
        {
          "id": "s3",
          "text": "他抓住叶子用力拔：“嗨哟，嗨哟！”可是拔不动。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s4",
          "text": "老爷爷叫来老奶奶，老奶奶拉住老爷爷。"
        },
        {
          "id": "s5",
          "text": "“嗨哟，嗨哟！”还是拔不动。"
        },
        {
          "id": "s6",
          "text": "老奶奶叫来小孙女，小孙女拉住老奶奶。"
        },
        {
          "id": "s7",
          "text": "“嗨哟，嗨哟！”还是拔不动。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s8",
          "text": "小孙女叫来小狗，小狗拉住小孙女。"
        },
        {
          "id": "s9",
          "text": "“嗨哟，嗨哟！”还是拔不动。"
        },
        {
          "id": "s10",
          "text": "小狗叫来小猫，小猫拉住小狗。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s11",
          "text": "大家一起使劲：“嗨哟，嗨哟！”"
        },
        {
          "id": "s12",
          "text": "“啵”的一声，大萝卜终于拔出来啦！"
        },
        {
          "id": "s13",
          "text": "大家开心地笑了，原来齐心协力力量大。"
        }
      ]
    }
  ]
}
