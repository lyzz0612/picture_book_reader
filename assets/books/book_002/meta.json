  "pages": [
    {
      "id": "p1",
      "segments": [
        { "id": "s1", "text": "夜深了，月亮悄悄爬上了树梢。" },
        { "id": "s2", "text": "小熊躺在妈妈的怀里，听妈妈讲故事。" },
        { "id": "s3", "text": "慢慢地，小熊闭上了眼睛。" }
      ]
    },
    {
      "id": "p2",
      "segments": [
        { "id": "s4", "text": "星星眨着眼睛，守护着小熊的梦。" },
        { "id": "s5", "text": "晚安，小熊。晚安，整个世界。" }
      ]
    }
  ]
}
