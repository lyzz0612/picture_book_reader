{
  "id": "book_005",
  "title": "灰姑娘",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "从前有个善良的女孩，叫灰姑娘。"
        },
        {
          "id": "s2",
          "text": "继母和姐姐们让她干所有的活，还不让她休息。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "一天，王宫举办舞会。灰姑娘很想去，却只能在家里哭泣。"
        },
        {
          "id": "s4",
          "text": "这时，一位温柔的仙母出现了，她挥动魔杖，把南瓜变成马车，把灰姑娘打扮得漂漂亮亮。"
        },
        {
          "id": "s5",
          "text": "仙母叮嘱：“孩子，记住，到了午夜魔法就会消失。”"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "舞会上，王子和灰姑娘跳了一支又一支舞。"
        },
        {
          "id": "s7",
          "text": "当钟声响起，灰姑娘急忙跑回家，路上落下了一只水晶鞋。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "王子拿着水晶鞋，挨家挨户地寻找。"
        },
        {
          "id": "s9",
          "text": "终于，水晶鞋正好合灰姑娘的脚。"
        },
        {
          "id": "s10",
          "text": "善良的灰姑娘和王子过上了幸福的生活。"
        }
      ]
    }
  ]
}
