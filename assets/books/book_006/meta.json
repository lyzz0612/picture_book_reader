{
  "id": "book_006",
  "title": "白雪公主",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 6,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "很久很久以前，有位公主皮肤白得像雪，叫白雪公主。"
        },
        {
          "id": "s2",
          "text": "王后嫉妒她的美丽，白雪公主只好逃进了深深的森林。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "森林里有一座小房子，住着七个小矮人。"
        },
        {
          "id": "s4",
          "text": "小矮人们很善良，热情地收留了白雪公主。"
        },
        {
          "id": "s5",
          "text": "他们一起唱歌、跳舞，日子过得十分快乐。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "可是，王后扮成老婆婆，送给白雪公主一个红苹果。"
        },
        {
          "id": "s7",
          "text": "白雪公主咬了一口，就沉沉地睡了过去。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "小矮人们伤心地守着她。"
        },
        {
          "id": "s9",
          "text": "这时，一位路过的王子前来探望。"
        },
        {
          "id": "s10",
          "text": "他轻轻一唤，白雪公主睁开了眼睛，大家都欢呼起来。"
        }
      ]
    },
    {
      "id": "p5",
      "segments": [
        {
          "id": "s11",
          "text": "原来，真正美丽的是一颗善良的心。"
        },
        {
          "id": "s12",
          "text": "从此，白雪公主和大家幸福地生活在一起。"
        }
      ]
    }
  ]
}
