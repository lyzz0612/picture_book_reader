{
  "id": "book_036",
  "title": "小狗穿衣",
  "coverPath": "books/book_036/cover.png",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "category": "lifeHabit",
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "早上，阳光照进窗户，小狗醒了。“该起床穿衣服啦！”狗妈妈说。"
        },
        {
          "id": "s2",
          "text": "小狗摇摇头：“妈妈，你帮我穿吧！我不会穿！”"
        },
        {
          "id": "s3",
          "text": "狗妈妈笑着说：“小狗长大了，要学会自己穿衣服！妈妈教你！”"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s4",
          "text": "狗妈妈拿出袜子：“先穿袜子。把脚尖伸进袜子里，然后拉上去！”"
        },
        {
          "id": "s5",
          "text": "小狗拿起袜子，把脚伸进去，可是袜子总是歪歪扭扭的。“妈妈，袜子不听话！”小狗着急地说。"
        },
        {
          "id": "s6",
          "text": "“慢慢来，不要着急！”狗妈妈说。小狗慢慢试，终于把袜子穿好了！"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s7",
          "text": "接着穿裤子。狗妈妈说：“先把裤腿套在脚上，然后提上去！”"
        },
        {
          "id": "s8",
          "text": "小狗把两只脚都伸进裤腿里，可是裤子前后穿反了，屁股后面跑到前面来了！"
        },
        {
          "id": "s9",
          "text": "“裤子穿反啦！”狗妈妈笑着说，“看，前面有小口袋！”小狗把裤子转过来，重新穿上，这次对了！"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s10",
          "text": "最后穿外套。狗妈妈说：“先把一只手伸进袖子里，再把另一只手伸进去，然后拉拉链！”"
        },
        {
          "id": "s11",
          "text": "小狗把两只手都伸进袖子里，可是拉链怎么也拉不上。“哎呀，拉链卡住了！”小狗说。"
        },
        {
          "id": "s12",
          "text": "狗妈妈帮小狗整理了一下衣服：“看，衣服要对齐，拉链才能拉上去！”小狗照着做，拉链“咔嗒咔嗒”地拉上去了！"
        }
      ]
    },
    {
      "id": "p5",
      "segments": [
        {
          "id": "s13",
          "text": "小狗穿好衣服，照了照镜子：“妈妈，你看！我自己穿好衣服啦！”"
        },
        {
          "id": "s14",
          "text": "狗妈妈笑着说：“我们小狗真棒！自己会穿衣服啦！”"
        },
        {
          "id": "s15",
          "text": "小狗开心地跑出去找小伙伴们玩。小伙伴们都夸小狗：“小狗真能干！自己会穿衣服！”"
        },
        {
          "id": "s16",
          "text": "小狗骄傲地说：“是呀！我长大了，自己的事情自己做！”"
        }
      ]
    }
  ]
}