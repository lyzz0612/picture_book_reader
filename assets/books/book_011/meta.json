{
  "id": "book_011",
  "title": "牛郎织女",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "很久以前，人间有个善良的小伙子叫牛郎。"
        },
        {
          "id": "s2",
          "text": "天上有个心灵手巧的仙女叫织女。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "一天，织女下凡游玩，和牛郎相遇了。"
        },
        {
          "id": "s4",
          "text": "两人相爱成亲，男耕女织，生活十分幸福。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s5",
          "text": "王母娘娘知道后很生气，把织女带回了天上。"
        },
        {
          "id": "s6",
          "text": "牛郎挑着两个孩子追到天上，眼看就要追上。"
        },
        {
          "id": "s7",
          "text": "王母娘娘拔下金簪一划，天上出现了一条银河。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "牛郎和织女被隔在银河两边，只能远远相望。"
        },
        {
          "id": "s9",
          "text": "他们的深情打动了喜鹊。"
        },
        {
          "id": "s10",
          "text": "每年七月初七，成千上万的喜鹊搭成鹊桥，让一家人团聚。"
        }
      ]
    }
  ]
}
