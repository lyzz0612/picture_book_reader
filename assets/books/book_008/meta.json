{
  "id": "book_008",
  "title": "丑小鸭",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "夏天，鸭妈妈孵出了一只又大又丑的小鸭。"
        },
        {
          "id": "s2",
          "text": "大家都叫他“丑小鸭”，还嘲笑他、欺负他。"
        },
        {
          "id": "s3",
          "text": "丑小鸭伤心极了，偷偷离开了家。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s4",
          "text": "秋天来了，丑小鸭独自在湖边生活，没有朋友。"
        },
        {
          "id": "s5",
          "text": "冬天，湖面结了冰，他在寒冷中苦苦地挨过了漫长的冬天。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "春天终于来了，丑小鸭伸展翅膀，发现自己飞了起来。"
        },
        {
          "id": "s7",
          "text": "他低头一看，水里倒映着一只雪白美丽的天鹅。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "原来他不是丑小鸭，而是一只天鹅！"
        },
        {
          "id": "s9",
          "text": "其他天鹅围过来，热情地欢迎他。"
        },
        {
          "id": "s10",
          "text": "丑小鸭终于明白：每个人都有自己的成长时刻。"
        }
      ]
    }
  ]
}
