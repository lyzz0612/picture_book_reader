{
  "id": "book_013",
  "title": "猴子捞月",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 4,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "一天夜里，一群猴子在井边玩耍。"
        },
        {
          "id": "s2",
          "text": "突然，一只小猴子叫起来：“不好啦，月亮掉进井里了！”"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "老猴子跑来一看，井里果然有个月亮。"
        },
        {
          "id": "s4",
          "text": "他大喊：“快，我们把它捞上来！”"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s5",
          "text": "猴子们一只接一只倒挂在树枝上，伸长手去够水面。"
        },
        {
          "id": "s6",
          "text": "老猴子在最上面，小猴子在最下面。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s7",
          "text": "小猴子的手一碰到水，水面就晃动起来。"
        },
        {
          "id": "s8",
          "text": "月亮一下子不见了！"
        },
        {
          "id": "s9",
          "text": "大家抬头一看，月亮还好好地挂在天上呢。"
        },
        {
          "id": "s10",
          "text": "原来井里的只是月亮的影子呀。"
        }
      ]
    }
  ]
}
