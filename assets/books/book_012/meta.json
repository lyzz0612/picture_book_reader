{
  "id": "book_012",
  "title": "八仙过海",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "传说有八位神仙，叫作“八仙”。"
        },
        {
          "id": "s2",
          "text": "一天，他们参加完宴会，要渡过大海回家。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "铁拐李说：“我们各显神通，不坐船，自己过海吧。”"
        },
        {
          "id": "s4",
          "text": "大家都拍手叫好。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s5",
          "text": "铁拐李把葫芦抛进海里，站在上面漂了过去。"
        },
        {
          "id": "s6",
          "text": "汉钟离把芭蕉扇扔到水上，悠闲地扇着风。"
        },
        {
          "id": "s7",
          "text": "何仙姑把荷花放入海中，化作一叶小舟。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "其他仙人也各显本领，有的骑驴，有的吹箫。"
        },
        {
          "id": "s9",
          "text": "不一会儿，八位仙人都高高兴兴地过了海。"
        },
        {
          "id": "s10",
          "text": "这个故事告诉我们：每个人都有自己的长处。"
        }
      ]
    }
  ]
}
