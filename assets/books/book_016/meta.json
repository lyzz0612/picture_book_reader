{
  "id": "book_016",
  "title": "老鼠嫁女儿",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "老鼠爸爸有个漂亮的女儿，想把她嫁给世界上最厉害的人。"
        },
        {
          "id": "s2",
          "text": "他抬头一看，太阳又亮又暖，就去问太阳。"
        },
        {
          "id": "s3",
          "text": "太阳说：“云能遮住我，云比我厉害。”"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s4",
          "text": "老鼠爸爸去找云。"
        },
        {
          "id": "s5",
          "text": "云说：“风能吹散我，风比我厉害。”"
        },
        {
          "id": "s6",
          "text": "老鼠爸爸又去找风。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s7",
          "text": "风说：“墙能挡住我，墙比我厉害。”"
        },
        {
          "id": "s8",
          "text": "老鼠爸爸又去找墙。"
        },
        {
          "id": "s9",
          "text": "墙说：“老鼠能在我身上打洞，老鼠比我厉害。”"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s10",
          "text": "老鼠爸爸想了想，哈哈大笑起来。"
        },
        {
          "id": "s11",
          "text": "“原来最厉害的就是我们老鼠呀！”"
        },
        {
          "id": "s12",
          "text": "于是，他把女儿嫁给了一位英俊的小老鼠。"
        }
      ]
    }
  ]
}
