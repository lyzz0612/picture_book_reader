  "pages": [
    {
      "id": "p1",
      "segments": [
        { "id": "s1", "text": "小龟有一罐甜甜的糖果，是奶奶送给他的生日礼物。糖果有草莓味、橘子味、苹果味，五颜六色的，好看极了！" },
        { "id": "s2", "text": "小伙伴们来小龟家玩，看到糖果都很想吃。“小龟，能给我一颗吗？”小兔问。" },
        { "id": "s3", "text": "小龟摇摇头：“不行！这是我的糖果！”小伙伴们只好走开了。" }
      ]
    },
    {
      "id": "p2",
      "segments": [
        { "id": "s4", "text": "小龟一个人坐在角落里，一颗一颗地吃糖果。可是，一个人吃糖果，好像没那么甜了……" },
        { "id": "s5", "text": "小龟看到小伙伴们在另一边玩游戏，笑得好开心！他想加入，可是又不好意思。" },
        { "id": "s6", "text": "“如果我分享糖果，他们会不会和我一起玩呢？”小龟心想。" }
      ]
    },
    {
      "id": "p3",
      "segments": [
        { "id": "s7", "text": "小龟鼓起勇气，拿着糖果罐走过去：“小兔，给你一颗草莓味的！”" },
        { "id": "s8", "text": "小兔开心地接过糖果：“谢谢小龟！真甜！”" },
        { "id": "s9", "text": "小龟又分给小狗一颗橘子味的，分给小猫一颗苹果味的。小伙伴们都开心地说：“谢谢小龟！”" }
      ]
    },
    {
      "id": "p4",
      "segments": [
        { "id": "s10", "text": "“小龟，我们一起玩游戏吧！”小兔说。大家拉着小龟一起玩，笑声像银铃一样！" },
        { "id": "s11", "text": "小龟发现，和小伙伴们一起玩，比一个人吃糖果开心多了！" },
        { "id": "s12", "text": "虽然糖果少了，但是快乐变多了！" }
      ]
    },
    {
      "id": "p5",
      "segments": [
        { "id": "s13", "text": "从那以后，小龟学会了分享。有好吃的分给小伙伴，有好玩的一起玩。" },
        { "id": "s14", "text": "大家都喜欢和小龟做朋友。小龟说：“分享真快乐！好东西要和好朋友一起分享！”" }
      ]
    }
  ]
}
