  "title": "小龟分享",
  "coverPath": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=cute%20turtle%20sharing%20candy%20with%20friends%2C%20children%27s%20picture%20book%20style%2C%20warm%20and%20friendly&image_size=square",
  "mode": "textOnly",
