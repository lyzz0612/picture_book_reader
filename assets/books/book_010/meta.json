{
  "id": "book_010",
  "title": "狼来了",
  "coverPath": "",
  "mode": "textOnly",
  "estimatedMinutes": 5,
  "pages": [
    {
      "id": "p1",
      "segments": [
        {
          "id": "s1",
          "text": "从前，有个放羊娃每天在山上放羊。"
        },
        {
          "id": "s2",
          "text": "日子久了，他觉得十分无聊。"
        }
      ]
    },
    {
      "id": "p2",
      "segments": [
        {
          "id": "s3",
          "text": "一天，他大喊：“狼来了！狼来了！”"
        },
        {
          "id": "s4",
          "text": "村民们急忙跑上山，却发现没有狼。"
        },
        {
          "id": "s5",
          "text": "放羊娃哈哈大笑，觉得好玩极了。"
        }
      ]
    },
    {
      "id": "p3",
      "segments": [
        {
          "id": "s6",
          "text": "第二天，他又喊“狼来了”，村民们又被骗了一次。"
        },
        {
          "id": "s7",
          "text": "大家都很生气，不再相信他了。"
        }
      ]
    },
    {
      "id": "p4",
      "segments": [
        {
          "id": "s8",
          "text": "第三天，真狼真的来了！"
        },
        {
          "id": "s9",
          "text": "放羊娃拼命喊救命，可没有人来。"
        },
        {
          "id": "s10",
          "text": "羊被狼叼走了，放羊娃后悔地哭了。"
        },
        {
          "id": "s11",
          "text": "从此他明白了：说谎的人，说真话也没人信。"
        }
      ]
    }
  ]
}
